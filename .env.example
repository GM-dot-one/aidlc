# ---------- OpenProject ----------
# Base URL of your local OpenProject instance
OPENPROJECT_URL=http://localhost:8080
# Generate in OpenProject: My Account -> Access tokens -> API
OPENPROJECT_API_KEY=replace-me
# Default project identifier (slug) the agent operates in
OPENPROJECT_PROJECT=ai-dlc-demo

# ---------- LLM provider ----------
# One of: anthropic, groq
AIDLC_LLM_PROVIDER=anthropic

# --- Anthropic (paid) ---
ANTHROPIC_API_KEY=replace-me
# Model id — keep in sync with aidlc/llm/anthropic.py defaults
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Groq (has a free tier) ---
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=replace-me
# Free-tier friendly default. See https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# ---------- GitHub ----------
# Fine-grained PAT scoped to the target repo, with contents:rw + pull-requests:rw
GITHUB_TOKEN=replace-me
# Repo the agent should open PRs against, e.g. acme-corp/erp-core
GITHUB_REPO=owner/repo
# Base branch PRs target
GITHUB_BASE_BRANCH=main

# ---------- Agent runtime ----------
# SQLite path (relative to repo root)
AIDLC_DB_PATH=.aidlc/state.db
# Scratch directory used by task_to_code when cloning/patching the target repo
AIDLC_WORKDIR=.aidlc/workdir
AIDLC_LOG_LEVEL=INFO

# ---------- OpenProject docker stack (used by docker-compose.yml) ----------
OPENPROJECT_HOST_PORT=8080
OPENPROJECT_SECRET_KEY_BASE=change-me-to-a-long-random-string
OPENPROJECT_HTTPS=false
OPENPROJECT_HOST__NAME=localhost:8080
OPENPROJECT_DEFAULT__LANGUAGE=en
